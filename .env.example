# Local: copy to `.env.local`. Production: paste each KEY=VALUE row into your
# hosting env vars (same names, no quotes).
# NEXT_PUBLIC_* vars are exposed to the browser. All others are server-only.

# Supabase — supabase.com/dashboard → your project → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxx
# Server-only. Bypasses RLS — never expose to the client, never prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxx

# Password that unlocks edit mode on the calendar. Server-only.
# Pick something long. Session persists via an httpOnly cookie after entering it.
ADMIN_PASSWORD=change-me-to-something-long-and-unguessable

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=clerk-pub-key
CLERK_SECRET_KEY=clerk-secret-key